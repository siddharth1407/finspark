# ===========================================
# SyncBridge AI - Environment Configuration
# ===========================================

# AI Provider - HuggingFace (FREE)
AI_PROVIDER=huggingface
HUGGINGFACE_API_KEY=hf_your_key_here

# Recommended Models (all free on HuggingFace):
# - Qwen/Qwen2.5-72B-Instruct (best quality, ~60s per request)
# - mistralai/Mistral-7B-Instruct-v0.2 (faster, good quality)
AI_MODEL=Qwen/Qwen2.5-72B-Instruct

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Security
SECRET_KEY=change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database (optional - uses in-memory by default)
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost/syncbridge
